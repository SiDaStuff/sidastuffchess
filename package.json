  },
  "dependencies": {
    "chess.js": "^0.10.3",
    "firebase-admin": "^12.0.0",
    "stockfish": "^18.0.7",
    "express": "^4.18.2",
    "morgan": "^1.10.0"
    ,
    "dotenv": "^16.0.0"
  }
}
