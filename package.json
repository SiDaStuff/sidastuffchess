{
  "name": "sidastuff-chess-review",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "node scripts/copy-stockfish.mjs",
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
